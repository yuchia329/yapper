# Copy to .env and fill in. .env is gitignored.

# 解說 script brain (OpenAI-compatible API — MiniMax, or a self-hosted vLLM URL)
LLM_API_KEY=
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M3

# GPU box (6x RTX 3090, ssh nlp) gRPC inference services. host:port, no scheme.
# The standalone CLI dials these FIXED endpoints — point them at running WhisperX (ASR) /
# CosyVoice2 (TTS) servers, e.g. over an SSH tunnel:
#   ssh -N -L 50051:localhost:50051 -L 50052:localhost:50052 nlp
# (On-demand pools via gpud are a *platform* feature — the web workers lease per task — and
#  are NOT used by the CLI. See deploy/.env.example and deploy/env/*.env for the gpud default.)
ASR_GRPC_TARGET=localhost:50051
TTS_GRPC_TARGET=localhost:50052

# HuggingFace token for pyannote diarization (used on the server side)
HF_TOKEN=
