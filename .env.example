# Copy to .env and fill in. .env is gitignored.

# 解说 script brain (OpenAI-compatible API — MiniMax, or a self-hosted vLLM URL)
LLM_API_KEY=
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M3

# GPU server (6x RTX 3090, ssh nlp) inference services, reached over the network
# (typically an SSH tunnel: ssh -N -L 8900:localhost:8900 -L 8901:localhost:8901 nlp)
ASR_SERVER_URL=http://localhost:8900
TTS_SERVER_URL=http://localhost:8901

# HuggingFace token for pyannote diarization (used on the server side)
HF_TOKEN=
