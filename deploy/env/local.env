# LOCAL profile — MinIO (S3-compatible) for files, no AWS. Used by docker-compose.local.yml.
# Fill LLM_API_KEY and point the gRPC targets at your GPU box (or an SSH tunnel).

# --- LLM + cost cap ---
LLM_API_KEY=
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M3
LLM_MAX_COST_USD=3.0

# --- GPU box gRPC inference. DEFAULT = on-demand pools via gpud (scale-to-zero): the worker
# leases an ASR/TTS instance per task; gpud launches it on a free GPU and reaps it when idle.
# The in-compose `gpu-tunnel` sidecar SSHes to the box and forwards gpud, so workers dial it by
# service name (no host-side scripts/gpu_tunnel.sh needed). The sidecar reads GPU_HOST/GPU_USER/
# GPU_PORT below — set the REAL box values in local.env.mine (gitignored).
GPU_SUPERVISOR_TARGET=gpu-tunnel:50050
# GPU box identity for the gpu-tunnel sidecar (real values -> local.env.mine):
# GPU_HOST=your-gpu-box.example.edu
# GPU_USER=you
# GPU_PORT=22
# Host-script alternative (skip the sidecar): set GPU_SUPERVISOR_TARGET=host.docker.internal:50050
# and run `BIND=0.0.0.0 bash scripts/gpu_tunnel.sh nlp` on the host (ensures gpud + a BACKGROUND
# tunnel, idempotent; stop it with `bash scripts/gpu_tunnel.sh down`).
# Always-on fallback — ONLY if you disable gpud: unset GPU_SUPERVISOR_TARGET above, uncomment
# these, and tunnel 50051/50052 to hand-run asr/tts servers instead.
# ASR_GRPC_TARGET=host.docker.internal:50051
# TTS_GRPC_TARGET=host.docker.internal:50052

# --- storage: MinIO ---
STORAGE_BACKEND=s3
S3_BUCKET=jieshuo-artifacts
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000          # api/workers reach MinIO in-network
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000  # browser-reachable host for presigned URLs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- infra (compose service names) ---
DATABASE_URL=postgresql+psycopg://jieshuo:jieshuo@postgres:5432/jieshuo
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=jieshuo
WORK_ROOT=/scratch/work
PUSHGATEWAY_URL=http://pushgateway:9091

# --- sessions (http dev: cookie not secure) ---
SESSION_SECRET=dev-insecure-change-me
COOKIE_SECURE=false
SESSION_MAX_AGE=31536000

# --- quotas ---
MAX_MOVIES_PER_SESSION=0   # 0 = unlimited (no per-session movie cap)
MAX_CONCURRENT_RUNS=2
PIPELINE_CONFIG=/app/config/pipeline.toml
