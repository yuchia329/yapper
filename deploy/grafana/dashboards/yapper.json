{
  "uid": "yapper-overview",
  "title": "Yapper · Overview",
  "tags": ["yapper", "yapper"],
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API up",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] }, "overrides": [] },
      "targets": [{ "expr": "max(up{namespace=\"yapper\", service=\"api\"})", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "gpud reachable",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] }, "overrides": [] },
      "targets": [{ "expr": "max(up{namespace=\"yapper\", service=\"gpu-tunnel\"})", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Runs in progress",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "yapper_runs_in_progress", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Runs in error",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "targets": [{ "expr": "sum(yapper_runs{status=\"error\"})", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Root disk free %",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 15 }, { "color": "green", "value": 30 }] } }, "overrides": [] },
      "targets": [{ "expr": "100 * (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})", "refId": "A" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Celery queue depth",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "yapper_queue_depth", "legendFormat": "{{queue}}", "refId": "A" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Runs by status",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "yapper_runs", "legendFormat": "{{status}}", "refId": "A" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "gpud instances (idle/leased)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "yapper_gpud_instances", "legendFormat": "{{service}}/{{state}}", "refId": "A" }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GPU VRAM used per GPU",
      "description": "VRAM consumed per GPU (total - free). Rising bars = less headroom before the next ASR (~7.6GB) / TTS (~4.5GB) instance can launch.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "decmbytes", "min": 0 }, "overrides": [] },
      "targets": [{ "expr": "yapper_gpud_gpu_total_mb - yapper_gpud_gpu_free_mb", "legendFormat": "gpu {{gpu}}", "refId": "A" }]
    },

    { "id": 100, "type": "row", "title": "Pipeline stage timing", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 } },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Back-half stage time (avg, latest)",
      "description": "Mean wall time per back-half stage (understand/script/tts/edl/subs/render). One bar per stage at its latest value — far more legible than a flat trend when run volume is low. Hover the row for the trend.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false } },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [{ "expr": "yapper_stage_seconds_avg{scope=\"run\", status=\"ran\"}", "legendFormat": "{{stage}}", "refId": "A" }]
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Front-half stage time (avg, latest)",
      "description": "Mean wall time per front-half stage (ingest/audio/asr/shots/scenes) over recent movies. One bar per stage at its latest value — clearer than a trend at low volume.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false } },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [{ "expr": "yapper_stage_seconds_avg{scope=\"movie\", status=\"ran\"}", "legendFormat": "{{stage}}", "refId": "A" }]
    },

    { "id": 101, "type": "row", "title": "Stage activity & LLM spend", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 } },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Stage running now",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "targets": [{ "expr": "yapper_stage_running", "legendFormat": "{{scope}}/{{stage}}", "refId": "A" }]
    },
    {
      "id": 18,
      "type": "bargauge",
      "title": "LLM spend by stage (cumulative)",
      "description": "Cumulative MiniMax USD attributed to the understand (vision MAP) vs script (reasoning REDUCE) pass. This is a running total, so a time series just steps up at each run — a bar of the current total per stage reads better.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 30 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false } },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "min": 0 }, "overrides": [] },
      "targets": [{ "expr": "yapper_llm_stage_cost_usd_total", "legendFormat": "{{stage}}", "refId": "A" }]
    },
    {
      "id": 19,
      "type": "bargauge",
      "title": "LLM tokens by stage (cumulative)",
      "description": "Cumulative LLM tokens per stage and direction (in/out). Running total — a bar of the current value per series is clearer than a stepping trend at low volume.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false } },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [{ "expr": "yapper_llm_stage_tokens_total", "legendFormat": "{{stage}} {{direction}}", "refId": "A" }]
    },

    { "id": 102, "type": "row", "title": "Render & host pressure (node-exporter)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 } },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Host CPU busy (cores)",
      "description": "Cores busy on the box (node-exporter — same source as 'Root disk free %'). Render is the dominant CPU user on this single 2-vCPU node, so sustained ~2 = render is CPU-bound. NOTE: the old per-container query needed a cAdvisor/kubelet scrape, which this Prometheus does not have.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(node_cpu_seconds_total{mode!=\"idle\"}[5m]))", "legendFormat": "cores busy", "refId": "A" }]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Host load avg vs cores",
      "description": "Run-queue pressure (node_load1/5). When load climbs above the core count (~2) the box is oversubscribed — the real 'render starves everything' signal on a single node. Replaces the old CPU-throttle query, which showed NO data: nothing here scrapes cAdvisor, and with a cpu:\"2\" limit equal to the 2-core box, CFS throttling never fires anyway.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "none", "min": 0, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 2 }, { "color": "red", "value": 4 }] } }, "overrides": [] },
      "targets": [
        { "expr": "node_load1", "legendFormat": "load 1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "load 5m", "refId": "B" }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Host memory used %",
      "description": "Box memory pressure (node-exporter). The worker shares this 8GB box with redis/postgres/api; sustained >90% risks an OOM during render. NOTE: the old per-container working-set query needed a cAdvisor scrape, which is absent here.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }] } }, "overrides": [] },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "legendFormat": "mem used %", "refId": "A" }]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Render realtime-factor (output_s / render_s)",
      "description": "Encode efficiency. <1 = slower-than-realtime CPU encode (the symptom of x264 'medium' with no -preset/-threads tuning).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "targets": [{ "expr": "yapper_render_rtf", "legendFormat": "{{lang}}", "refId": "A" }]
    },

    { "id": 103, "type": "row", "title": "GPU memory & ASR/TTS pool", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 } },
    {
      "id": 17,
      "type": "timeseries",
      "title": "GPU memory used %",
      "description": "1 - free/total per GPU. Headroom before the next ASR (~7.6GB) / TTS (~4.5GB) instance can launch.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 56 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "expr": "100 * (1 - yapper_gpud_gpu_free_mb / yapper_gpud_gpu_total_mb)", "legendFormat": "gpu {{gpu}}", "refId": "A" }]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "ASR/TTS processes by lifecycle",
      "description": "Pooled model-server subprocess count per service: leased (busy) / starting (cold load) / idle (warm).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "targets": [{ "expr": "yapper_gpud_instances", "legendFormat": "{{service}}/{{state}}", "refId": "A" }]
    }
  ]
}
